{
  "name": "video-tuner-pro",
  "version": "2.0.5",
  "description": "Build tooling for the Video Tuner Pro browser extension",
  "license": "GPL-3.0-only",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "check": "tsc --noEmit",
