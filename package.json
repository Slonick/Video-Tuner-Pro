    "screenshot": "node tools/screenshot.mjs",
    "promo": "node tools/promo.mjs",
    "promo:gif": "node tools/promo-gif.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
