{
  "name": "video-tuner-pro",
  "version": "2.4.0",
  "description": "Build tooling for the Video Tuner Pro browser extension",
  "license": "GPL-3.0-only",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "node tools/bench-dom.mjs",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "screenshot": "node tools/screenshot.mjs",
    "promo": "node tools/promo.mjs",
    "promo:gif": "node tools/promo-gif.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.1.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
